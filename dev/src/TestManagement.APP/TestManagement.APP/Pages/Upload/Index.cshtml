@page
@model IndexModel
@{
    ViewData["Title"] = "ファイルアップロード";
}

<div class="container">
    <form method="post" enctype="multipart/form-data">
        <div class="block">
            @if (!Model.ModelState.IsValid)
            {
                <div style="color:#e74c3c; margin-bottom:12px;">
                    @foreach (var err in Model.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            }
            <div class="block-title">テスト結果の登録</div>
            <div style="display:flex; flex-direction:column; gap:16px;">
                <div class="card" style="margin:0; border-width: thin; max-width: 50%;">
                    <div class="card-title">テストレベルを選択</div>
                    <div style="margin-bottom:8px;">
                        @if (Model.TestLevels != null && Model.TestLevels.Any())
                        {
                            <div style="margin:0;">
                                <select id="testLevelSelect" asp-for="SelectedTestLevelId" style="flex:0 0 20%; display:block; max-width:60%; padding:8px; margin-top:6px;">
                                    <option value="">選択してください</option>
                                    @foreach (var level in Model.TestLevels)
                                    {
                                        <option value="@level.Id">
                                            @level.Name @if(!string.IsNullOrWhiteSpace(level.Description)) {
                                                <text>- @level.Description</text>
                                            }
                                        </option>
                                    }
                                </select>
                            </div>
                        }
                        else
                        {
                            <div style="color:#e74c3c; margin:8px 0;">テストレベルを取得できませんでした。</div>
                        }
                    </div>
                </div>

                <div class="card" style="margin:0; border-width: thin; max-width: 50%;">
                    <div class="card-title">実行情報の指定（既存の選択または新規登録）</div>

                    @if (null != Model.ExecutionInfos && Model.ExecutionInfos.Any())
                    {
                        @* 既存の実行情報が存在しない場合には、実行情報の登録を強制したい。 *@
                        @* そのため、既存の実行情報がない場合には、ラジオボタンによる選択は行わせない。 *@
                        <div style="display:flex; gap:12px; align-items:center; margin-bottom:8px;">
                            <label style="display:flex; gap:6px; align-items:center;">
                                <input type="radio" name="executionMode" value="new" id="modeNew" checked />新規に登録する
                            </label>
                        </div>
                    }

                    <div id="newBlock" style="margin-left:24px; border:0px dashed #ddd; padding:8px; border-radius:4px; max-width:100%;">

                        <div style="display:flex; flex-direction:column; gap:8px;">
                            <label style="display:flex; flex-direction:column; gap:4px; margin-bottom: 8px;">
                                <span>リビジョン番号</span>
                                <input type="text" name="NewExecutionRevision" id="newRevision" placeholder="Ex). 123" style="padding:8px; max-width:100%;" />
                            </label>

                            <label style="display:flex; flex-direction:column; gap:4px;">
                                <span>実行日時（カレンダー・時刻）</span>
                                <input type="datetime-local" name="NewExecutionExecutedAt" id="newExecutedAt" style="padding:8px; max-width:100%;" />
                            </label>

                            <div style="font-size:0.9em; color:#666;">※ 新規登録を選択した場合、入力したリビジョンと日時がアップロード時にサーバへ送信され、新しい実行情報として登録されます。</div>
                        </div>
                    </div>

                    @if (null != Model.ExecutionInfos && Model.ExecutionInfos.Any())
                    {
                        @* 既存の実行情報が存在しない場合には、実行情報の登録を強制したい。 *@
                        @* そのため、既存の実行情報がない場合には、ラジオボタンによる選択は行わせない。 *@
                        <div style="display:flex; gap:12px; align-items:center; margin-bottom:8px;">
                            <label style="display:flex; gap:6px; align-items:center;">
                                <input type="radio" name="executionMode" value="existing" id="modeExisting" />既存の実行情報を指定
                            </label>
                        </div>

                        <div id="existingBlock" style="margin-left:24px; border:0px dashed #ddd; padding:8px; border-radius:4px; max-width:100%;">

                            <select id="executionInfoSelect" asp-for="SelectedExecutionInfoId" style="flex:0 0 30%; display:block; padding:8px; margin-top:6px;">
                                @foreach (var info in Model.ExecutionInfos)
                                {
                                    <option value="@info.Id">リビジョン @info.Abstract - @info.ExecutedAt.ToString("yyyy/MM/dd HH:mm")</option>
                                }
                            </select>

                            <div style="font-size:0.9em; color:#666; margin-top:6px;">※ 表示は「リビジョン番号 - 実行日時」です。選択肢はサーバ側のデータを使用します。</div>
                        </div>
                    }

                </div>

                <div class="card" style="margin:0; border-width: thin">
                    <div class="card-title">ファイルを選択</div>
                    <div style="margin-bottom: 8px;">
                        <input id="fileInput" type="file" asp-for="UploadFiles" multiple style="display:block; margin-top:6px;" />
                    </div>
                </div>

                <div style="margin-bottom:8px;">
                    <input type="submit" class="upload-btn" value="アップロード開始" />
                    <a asp-page="/Dashboard" style="margin-left:10px; text-decoration:none;">キャンセル</a>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    /* グレーアウト表示用: container remains normal; only form controls get disabled look */
    .grayed {
        background-color: #f7f7f7;
    }
    /* Controls other than the existing-radio appear disabled */
    .grayed input:not(#modeExisting), .grayed select, .grayed textarea, .grayed button {
         background-color: #f5f5f5;
         color: #6c6c6c;
     }
    /* Ensure the label around the existing radio keeps normal color when parent is grayed */
    .grayed .keep-normal {
        color: initial !important;
        opacity: 1 !important;
    }
</style>

<script>
    (function(){
        var modeExisting = document.getElementById('modeExisting');
        var modeNew = document.getElementById('modeNew');
        var existingBlock = document.getElementById('existingBlock');
        var newBlock = document.getElementById('newBlock');

        function setDisabledForBlock(block, disabled) {
            if (!block) return;
            if (disabled) {
                block.classList.add('grayed');
            } else {
                block.classList.remove('grayed');
            }
            var controls = block.querySelectorAll('input, select, textarea, button');
            controls.forEach(function(c){
                // Don't disable the radio buttons that control mode
                if (c.id === 'modeExisting' || c.id === 'modeNew') return;
                // Keep the underlying select enabled only when not disabled
                try { c.disabled = disabled; } catch (e) { /* ignore */ }
            });
        }

        function updateMode() {
            if (modeNew.checked) {
                // new enabled, existing disabled
                setDisabledForBlock(newBlock, false);
                setDisabledForBlock(existingBlock, true);
            } else {
                // existing enabled, new disabled
                setDisabledForBlock(newBlock, true);
                setDisabledForBlock(existingBlock, false);
            }
        }

        modeExisting.addEventListener('change', updateMode);
        modeNew.addEventListener('change', updateMode);

        // Initialize state
        updateMode();
    })();
</script>
